{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=NexaStoreDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "ServiceBus": {
    "ConnectionString": "",
    "OrderPlacedTopic": "order-placed",
    "OrderCancelledTopic": "order-cancelled",
    "PaymentCompletedTopic": "payment-completed"
  },
  "JwtSettings": {
    "Key": "REPLACE_WITH_32_CHAR_MIN_SECRET_KEY",
    "Issuer": "NexaStore",
    "Audience": "NexaStore",
    "DurationInMinutes": 60,
    "RefreshTokenDurationInDays": 7
  },
  "EmailSettings": {
    "ApiKey": "",
    "FromEmail": "noreply@nexastore.com",
    "FromName": "NexaStore"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
